DATABASE_URL=*********************************************/ghar360
# Railway/serverless deployments using Supabase must use the transaction
# pooler connection string on port 6543. Do not use the shared pooler session
# mode URL on port 5432 for SERVERLESS_ENABLED=true deployments.
# --- Database Connection Pool ---
# Ignored when SERVERLESS_ENABLED=true (NullPool). For non-serverless Supabase
# session-pooler deployments, keep total main+background capacity low.
# DB_POOL_SIZE=4
# DB_MAX_OVERFLOW=0
# DB_POOL_TIMEOUT=15
# DB_POOL_RECYCLE=180
# Background pool (schedulers, scrapers, long-running tasks)
# DB_BG_POOL_SIZE=1
# DB_BG_MAX_OVERFLOW=0
# When true, skips in-process schedulers to allow scale-to-zero
# SERVERLESS_ENABLED=false
SUPABASE_URL=your_supabase_url
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
# HMAC secret used to verify inbound Supabase webhooks (e.g. password-changed
# session revocation). Generate with: openssl rand -hex 32
SUPABASE_WEBHOOK_SECRET=
# Encoding of the X-Supabase-Signature header: "hex" (default) or "base64".
SUPABASE_WEBHOOK_SIGNATURE_ENCODING=hex
# Short-lived cache for Supabase auth subject -> local user snapshot.
AUTH_USER_CACHE_TTL_SECONDS=45
# Flatmates app-wide realtime uses Supabase private Broadcast channels.
FLATMATES_REALTIME_ENABLED=true
SUPABASE_REALTIME_BROADCAST_TIMEOUT_SECONDS=2
# Google OAuth client IDs (optional) — surfaced to clients via GET /api/v1/auth/config.
# Leave unset/blank if Google sign-in is not configured for a given platform.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
SECRET_KEY=your_secret_key_here
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENABLE_TRACING=false
SENTRY_ENABLE_SQLALCHEMY_TRACING=false
ENABLE_SENTRY_TEST_ENDPOINT=false
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REDIS_URL=redis://localhost:6379
ENVIRONMENT=development
# Public base URL for OAuth/MCP (required for production)
# Set to your public API URL, e.g., https://api.360ghar.com
PUBLIC_BASE_URL=http://localhost:3600
# Public URL for the frontend app (used for share previews)
PUBLIC_APP_URL=https://360viewer.360ghar.com
PERPLEXITY_API_KEY=your_perplexity_api_key
PERPLEXITY_MODEL=sonar
SERPAPI_API_KEY=your_serpapi_api_key
SERPAPI_SEARCH_ENDPOINT=https://serpapi.com/search.json
FIREBASE_PROJECT_ID=your_firebase_project_id
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
ENABLE_NOTIF_SCHEDULER=false
NOTIF_SCHED_TZ=Asia/Kolkata
AUTO_BLOG_ENABLED=false
AUTO_BLOG_CRON=0 20 * * *
AUTO_BLOG_TIMEZONE=Asia/Kolkata
AUTO_BLOG_PUBLISHER_USER_ID=
AUTO_BLOG_MAX_POSTS_PER_RUN=3
AUTO_BLOG_MODEL=sonar
EMAIL_SENDER_ADDRESS=no-reply@360ghar.com
EMAIL_SENDER_NAME=360Ghar Notifications
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=smtp_user
EMAIL_SMTP_PASSWORD=smtp_password
SMS_PROVIDER_API_URL=https://sms.example.com/send
SMS_PROVIDER_API_KEY=your_sms_api_key
SMS_SENDER_ID=360GHAR

# Vector embeddings / Sync
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_EMBED_MODEL=text-embedding-004
VECTOR_SYNC_ENABLED=false
# Either provide CRON schedule or interval seconds
VECTOR_SYNC_CRON=
VECTOR_SYNC_INTERVAL_SECONDS=300
VECTOR_SYNC_BATCH_SIZE=500
VECTOR_SYNC_MAX_RETRIES=3

# GLM (ZhipuAI) API for Vastu Checker and Pydantic AI Agent
GLM_API_KEY=your_glm_api_key
GLM_API_URL=https://api.z.ai/api/coding/paas/v4/chat/completions
GLM_MODEL=glm-5v-turbo
VASTU_DEFAULT_PROVIDER=glm

# Groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=qwen/qwen3-32b

# AI Agent — fallback chain: GLM primary -> Gemini fallback -> Groq fallback
# API keys come from the shared provider env vars:
#   Primary:   GLM_API_KEY
#   Fallback:  GOOGLE_API_KEY
#   Fallback2: GROQ_API_KEY
AI_AGENT_MODEL=glm-4.7-flash
AI_AGENT_API_BASE=https://api.z.ai/api/coding/paas/v4
AI_AGENT_FALLBACK_MODEL=gemini-3.1-flash-lite-preview
AI_AGENT_FALLBACK_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
AI_AGENT_FALLBACK2_MODEL=qwen/qwen3-32b  # Optional; defaults to GROQ_MODEL

# ── Deep Links (App Links / Universal Links) ─────────────────────────────────
# Backend-driven deep linking for all 360Ghar apps. Replaces the separate
# static-hosted repos (ghar_sale_links / the360ghar_links).
#
# Canonical public domain the mobile apps declare in their native config. The
# backend must be reachable at this host (directly or via reverse-proxy) so that
# https://<DEEPLINK_DOMAIN>/.well-known/{assetlinks.json,apple-app-site-association}
# is served by this service for Android App Link / iOS Universal Link verification.
DEEPLINK_DOMAIN=the360ghar.com
# Apple Developer Team ID (10 chars) used to build AASA appIDs (TEAMID.bundleId).
# REQUIRED in production — replace the placeholder with the real Team ID.
DEEPLINK_APPLE_TEAM_ID=<your 10-char Apple Team ID>
# Android release SHA-256 signing-cert fingerprints per app (comma-separated,
# colon-delimited hex). Add upload + Play App Signing keys as needed. Get them
# via: keytool -list -v -keystore <keystore.jks> -alias <alias>
# (360 Ghar defaults are seeded in code; override here to rotate.)
DEEPLINK_GHAR_ANDROID_SHA256=E2:9C:60:26:A3:79:20:19:25:5F:93:BE:D1:35:CF:5F:3A:89:52:DD:44:EA:F9:41:08:87:7C:08:74:B0:64:E2
DEEPLINK_ESTATE_ANDROID_SHA256=22:D1:C2:25:DA:5E:3A:A9:98:C3:22:A7:C9:1D:F5:D8:1D:DD:FB:E3:31:3A:A5:C1:7B:40:D8:E0:79:07:85:3F
DEEPLINK_FLATMATES_ANDROID_SHA256=5F:D6:8C:1A:EB:C0:9C:85:B3:69:3C:D1:E4:C3:59:0B:E4:F8:9B:57:2C:3F:09:26:2D:2D:C7:31:F9:B0:F3:65
# Legacy FlatMates package (com.the360ghar.flatmates) — set only if the old app
# was signed with a DIFFERENT key. Left blank => legacy entry gets an empty
# fingerprint list (it never verifies against the wrong key).
DEEPLINK_FLATMATES_LEGACY_ANDROID_SHA256=
DEEPLINK_STAYS_ANDROID_SHA256=EE:6D:96:51:3A:2C:53:0D:33:66:6B:26:02:C4:1B:20:F3:5B:5D:65:94:CE:46:EF:B9:16:53:B3:5A:13:96:0D
